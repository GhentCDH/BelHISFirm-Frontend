    "facets": {
        "year": {
            "containerClass": "three",
            "facetType": "custom",
            "filterType": "CustomComponent",
            "componentName": "YearSelectFacet",
            "customFilterName": "yearBindStock",
            "minYear": 1830,
            "maxYear": 2000,
            "priority": 0
        },
        "scobID": {
            "sortByPredicate": "bhf:scobID"
        },
        "name": {
            "containerClass": "one",
            "facetType": "text",
            "filterType": "textFilter",
            "sortByPredicate": "bhf:hasName/rdfs:label",
            "textQueryProperty": "bhf:hasName/rdfs:label"
        },
        "stockExchange": {
            "containerClass": "three",
            "facetType": "list",
            "filterType": "uriFilter",
            "predicate": "bhf:hasStockExchange",
            "pieChartButton": true,
            "barChartButton": true,
            "searchField": false,
            "sortButton": true,
            "sortBy": "instanceCount",
            "sortByPredicate": "bhf:hasStockExchange",
            "sortDirection": "desc",
            "literal": true
        },
        "stocktype": {
            "containerClass": "ten",
            "facetType": "list",
            "filterType": "uriFilter",
            "predicate": "bhf:hasStockType/bhf:typeName",
