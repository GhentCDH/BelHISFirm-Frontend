{
    "id": "securities",
    "endpoint": {
        "url": "",
        "useAuth": false,
        "prefixesFile": "SparqlQueriesPrefixes.js",
        "defaultSparql": true
    },
    "generalQueries": {
        "facetResultSetQuery": "facetResultSetQueryStocks",
        "facetValuesQuery": "facetValuesQueryStocks",
        "countQuery": "countQueryStocks"
    },
    "sparqlQueriesFile": "ScobStocks.js",
    "baseURI": "http://belhisfirm.be/resource",
    "URITemplate": "<BASE_URI>/stock/<LOCAL_ID>",
    "facetClass": "bhf:Stock",
    "frontPageImage": "main_page/mmm-banner.jpg",
    "searchMode": "faceted-search",
    "enableDynamicLanguageChange": false,
    "defaultActiveFacets": [
        "year"
    ],
    "defaultTab": "table",
    "defaultInstancePageTab": "table",
    "resultClasses": {
        "securities": {
            "paginatedResultsConfig": {
                "tabID": 0,
                "component": "CustomComponent",
                "componentName": "GatedResultTable",
                "tabPath": "table",
                "tabIcon": "CalendarViewDay",
                "propertiesQueryBlock": "stocksProperties",
                "postprocess": { "func": "corporationNameForYear" },
                "pagesize": 20,
                "sortBy": "scobID",
                "sortDirection": "asc"
            },
            "instanceConfig": {
                "propertiesQueryBlock": "stockInstanceProperties",
                "instancePageResultClasses": {
                    "instancePageTable": {
                        "tabID": 0,
                        "component": "InstancePageTable",
                        "tabPath": "table",
                        "tabIcon": "CalendarViewDay",
                        "properties": [
                            {
                                "id": "scobID",
                                "valueType": "object",
                                "makeLink": true,
                                "externalLink": false,
                                "sortValues": true,
                                "numberedList": false,
                                "minWidth": 30
                            },
                            {
                                "id": "uri",
                                "valueType": "object",
                                "makeLink": false,
                                "sortValues": true,
                                "onlyOnInstancePage": true
                            },
                            {
                                "id": "name",
                                "valueType": "object",
                                "makeLink": true,
                                "externalLink": false,
                                "sortValues": true,
                                "sortBy": "startDate",
                                "numberedList": false,
                                "minWidth": 250
                            },
                            {
                                "id": "stockExchange",
                                "valueType": "object",
                                "makeLink": false,
                                "externalLink": false,
                                "sortValues": true,
                                "numberedList": false,
                                "minWidth": 300
                            },
                            {
                                "id": "stocktype",
                                "valueType": "object",
                                "makeLink": false,
                                "externalLink": false,
                                "sortValues": true,
                                "numberedList": false,
                                "minWidth": 200
                            },
                            {
                                "id": "sectorName",
                                "valueType": "object",
                                "makeLink": false,
                                "externalLink": false,
                                "sortValues": true,
                                "numberedList": false,
                                "minWidth": 150
                            },
                            {
                                "id": "sharetype",
                                "valueType": "object",
                                "makeLink": false,
                                "externalLink": false,
                                "sortValues": true,
                                "numberedList": false,
                                "minWidth": 175
                            },
                            {
                                "id": "corporationNames",
                                "valueType": "object",
                                "makeLink": true,
                                "externalLink": false,
                                "sortValues": true,
                                "numberedList": false,
                                "sortBy": "startDate",
                                "minWidth": 250
                            }
                        ]
                    }
                }
            }
        },
        "export": {
            "tabID": 1,
            "component": "CustomComponent",
            "componentName": "GatedExportCSV",
            "tabPath": "export",
            "tabIcon": "CloudDownload",
            "resultClass": "securities",
            "facetClass": "securities",
            "sparqlQuery": "securitiesExportQuery",
            "filterTarget": "id"
        }
    },
    "properties": [
