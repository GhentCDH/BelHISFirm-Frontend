@prefix :       <http://belhisfirm.be/resource/> .
@prefix bhf:    <http://belhisfirm.be/ontology#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix org:    <http://www.w3.org/ns/org#> .
@prefix rov:    <http://www.w3.org/ns/regorg#> .
@prefix schema: <http://schema.org/> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix vcard:  <http://www.w3.org/2006/vcard/ns#> .
@prefix rr:     <http://www.w3.org/ns/r2rml#> .

#################
# CORPORATION
##################
:CORPORATION-TYPE
    a               rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """SELECT id FROM scoball.corporation""" ] ;
    rr:subjectMap   [ rr:template "http://belhisfirm.be/resource/corporation/{id}" ;
                      rr:class    bhf:Corporation ] .

:CORPORATION-NAME
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """SELECT corporation, RAWTOHEX(STANDARD_HASH(corporation || name || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) AS id
                                            FROM scoball.corporation_name WHERE name IS NOT NULL""" ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/corporation/{corporation}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasName ;
                            rr:objectMap [ rr:template "http://belhisfirm.be/resource/corporationName/{id}" ] ] .

:CORPORATION-LEGAL-FORM
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """SELECT corporation, RAWTOHEX(STANDARD_HASH(corporation || juridisch_statuut || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) AS id
                                            FROM scoball.corporation_juridisch_statuut WHERE juridisch_statuut IS NOT NULL""" ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/corporation/{corporation}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasLegalForm ;
                            rr:objectMap [ rr:template "http://belhisfirm.be/resource/legalForm/{id}" ] ] .

:CORPORATION-LOCATION
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """SELECT corporation, RAWTOHEX(STANDARD_HASH(corporation || city || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) AS id
                                                FROM scoball.corporation_location""" ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/corporation/{corporation}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasAddress ;
                            rr:objectMap [ rr:template "http://belhisfirm.be/resource/address/{id}" ] ] .

:CORPORATION-PROPERTIES
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                                            SELECT id,
                                            CASE
                                                WHEN cn.earliest_startdate <= TO_DATE('1005-12-31','YYYY-MM-DD') THEN NULL
                                                ELSE TO_CHAR(cn.earliest_startdate, 'YYYY-MM-DD')
                                            END AS startdate,
                                            CASE
                                                WHEN c.enddate >= TO_DATE('3900-01-01','YYYY-MM-DD') THEN NULL
                                                ELSE TO_CHAR(c.enddate, 'YYYY-MM-DD')
                                            END AS enddate
                                            FROM scoball.corporation c
                                            JOIN (
                                                SELECT corporation, MIN(startdate) as earliest_startdate
                                                FROM scoball.corporation_name cn
                                                GROUP BY corporation
                                            ) cn ON cn.corporation = c.id
                                       """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/corporation/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:dateOfIncorporation ;
                            rr:objectMap [ rr:column   "startdate" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:dateOfDissolution ;
                            rr:objectMap [ rr:column   "enddate" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:scobID ;
                            rr:objectMap [ rr:column   "id" ;
                                           rr:datatype xsd:integer ] ] .

:CORPORATION-STOCK-CORPORATION
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT corporation,
                           RAWTOHEX(STANDARD_HASH(stock || corporation || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) AS id
                    FROM scoball.stock_corporation
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/corporation/{corporation}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasStockCorporation ;
                            rr:objectMap [ rr:template "http://belhisfirm.be/resource/stockcorporation/{id}" ] ] .

###################
# COROPORATION NAME
###################

:CORPORATION-NAME-TYPE
    a               rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery
                              """SELECT RAWTOHEX(STANDARD_HASH(corporation || name || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) AS id FROM scoball.corporation_name WHERE name IS NOT NULL""" ] ;
    rr:subjectMap   [ rr:template "http://belhisfirm.be/resource/corporationName/{id}" ;
                      rr:class    bhf:DatedName ] .

:CORPORATION-NAME-PROPERTIES
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                                        SELECT
                                            corporation,
                                            RAWTOHEX(STANDARD_HASH(corporation || name || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) AS id,
                                            name,
                                            startdate,
                                            CASE
                                                WHEN startdate <= TO_DATE('1005-12-31','YYYY-MM-DD') THEN NULL
                                                ELSE TO_CHAR(startdate, 'YYYY-MM-DD')
                                            END AS startdate_fixed,
                                            CASE
                                                WHEN enddate >= TO_DATE('3900-01-01','YYYY-MM-DD') THEN NULL
                                                ELSE TO_CHAR(enddate, 'YYYY-MM-DD')
                                            END AS enddate_fixed,
                                            source,
                                            comments
                                        FROM scoball.corporation_name
                                        WHERE name IS NOT NULL
                                        """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/corporationName/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate rdfs:label ;
                            rr:objectMap [ rr:column   "name" ;
                                           rr:datatype xsd:string ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:startDate ;
                            rr:objectMap [ rr:column   "startdate_fixed" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:endDate ;
                            rr:objectMap [ rr:column   "enddate_fixed" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:source ;
                            rr:objectMap [ rr:column   "source" ;
                                           rr:datatype xsd:string ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:comments ;
                            rr:objectMap [ rr:column   "comments" ;
                                           rr:datatype xsd:string ] ] .

# Links a corporation directly to the string of its single most recent dated name
# (greatest startdate). Reads from the SCOBALL.CORPORATION_LATEST_NAME lens (see lenses.json),
# which declares a unique key on CORPORATION so Ontop knows there is exactly one latest name
# per corporation (avoids DISTINCT fan-out). Maps the name as a plain literal.
:CORPORATION-LATEST-NAME
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:tableName "scoball.corporation_latest_name" ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/corporation/{corporation}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasLatestName ;
                            rr:objectMap [ rr:column   "corp_name" ;
                                           rr:datatype xsd:string ] ] .


##################
# LEGAL FORM
#################

:LEGAL-FORM-TYPE
    a               rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """SELECT corporation, RAWTOHEX(STANDARD_HASH(corporation || juridisch_statuut || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) AS id
                                    FROM scoball.corporation_juridisch_statuut WHERE juridisch_statuut IS NOT NULL""" ] ;
    rr:subjectMap   [ rr:template "http://belhisfirm.be/resource/legalForm/{id}" ;
                      rr:class    bhf:LegalForm ] .

:LEGAL-FORM-PROPERTIES
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
            SELECT
                cjs.corporation AS corporation,
                cjs.juridisch_statuut AS juridisch_statuut_id,
                js.juridisch_statuut  AS juridisch_statuut_label,
                RAWTOHEX(STANDARD_HASH(cjs.corporation || cjs.juridisch_statuut || TO_CHAR(cjs.startdate,'YYYY-MM-DD'), 'SHA1')) AS id,
                CASE
                    WHEN cjs.startdate <= TO_DATE('1005-12-31','YYYY-MM-DD') THEN NULL
                    ELSE TO_CHAR(cjs.startdate, 'YYYY-MM-DD')
                END AS startdate_fixed,
                CASE
                    WHEN cjs.enddate >= TO_DATE('3900-01-01', 'YYYY-MM-DD') THEN NULL
                    ELSE TO_CHAR(cjs.enddate, 'YYYY-MM-DD')
                END AS enddate_fixed,
                cjs.source,
                cjs.comments
            FROM scoball.corporation_juridisch_statuut cjs
            JOIN scoball.juridisch_statuut js
                ON cjs.juridisch_statuut = js.id
            WHERE cjs.juridisch_statuut IS NOT NULL
        """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/legalForm/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate rdfs:label ;
                            rr:objectMap [ rr:column   "juridisch_statuut_label" ;
                                           rr:datatype xsd:string ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:startDate ;
                            rr:objectMap [ rr:column   "startdate_fixed" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:endDate ;
                            rr:objectMap [ rr:column   "enddate_fixed" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:source ;
                            rr:objectMap [ rr:column   "source" ;
                                           rr:datatype xsd:string ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:comments ;
                            rr:objectMap [ rr:column   "comments" ;
                                           rr:datatype xsd:string ] ] .


###################
# LOCATION
##################
:LOCATION-TYPE
    a               rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """SELECT corporation, RAWTOHEX(STANDARD_HASH(corporation || city || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) AS id
                                        FROM scoball.corporation_location""" ] ;
    rr:subjectMap   [ rr:template "http://belhisfirm.be/resource/address/{id}" ;
                      rr:class    bhf:Address ] .

:LOCATION-PROPERTIES
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                                SELECT
                                    corporation,
                                    RAWTOHEX(STANDARD_HASH(corporation || city || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) AS id,
                                    address,
                                    city,
                                    CASE
                                        WHEN LOWER(city) = 'onbekend' THEN NULL
                                        ELSE city
                                    END AS city_fixed,
                                    CASE
                                        WHEN LOWER(country) = 'onbekend' THEN NULL
                                        ELSE country
                                    END AS country,
                                    CASE
                                        WHEN startdate <= TO_DATE('1005-12-31','YYYY-MM-DD') THEN NULL
                                        ELSE TO_CHAR(startdate, 'YYYY-MM-DD')
                                    END AS startdate_fixed,
                                    CASE
                                        WHEN enddate >= TO_DATE('3900-01-01','YYYY-MM-DD') THEN NULL
                                        ELSE TO_CHAR(enddate, 'YYYY-MM-DD')
                                    END AS enddate_fixed
                                FROM scoball.corporation_location;
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/address/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:streetAddress ;
                            rr:objectMap [ rr:column   "address" ;
                                           rr:datatype xsd:string ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:city ;
                            rr:objectMap [ rr:column   "city_fixed" ;
                                           rr:datatype xsd:string ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:country ;
                            rr:objectMap [ rr:column   "country" ;
                                           rr:datatype xsd:string ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:startDate ;
                            rr:objectMap [ rr:column   "startdate_fixed" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:endDate ;
                            rr:objectMap [ rr:column   "enddate_fixed" ;
                                           rr:datatype xsd:date ] ] .


###################
# STOCK
##################
:STOCK-TYPE
    a               rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
                    SELECT id FROM scoball.stock
    """ ] ;
    rr:subjectMap   [ rr:template "http://belhisfirm.be/resource/stock/{id}" ;
                      rr:class    bhf:Stock ] .

:STOCK-SCOBID
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                      SELECT id FROM scoball.stock
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/stock/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:scobID ;
                            rr:objectMap [ rr:column   "id" ;
                                           rr:datatype xsd:integer ] ] .

:STOCK-STOCKEXCHANGE
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT id,
                        CASE stockexchange
                            WHEN 1 THEN 'Brussels Stock Exchange'
                            WHEN 2 THEN 'Antwerp Stock Exchange'
                            ELSE Null
                        END AS exchange_name
                    FROM scoball.stock WHERE stockexchange IN (1, 2)
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/stock/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasStockExchange ;
                            rr:objectMap [ rr:column   "exchange_name" ;
                                           rr:datatype xsd:string ] ] .

:STOCK-NAME
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT stock,  RAWTOHEX(STANDARD_HASH(stock || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) as id
                    FROM scoball.stock_name
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/stock/{stock}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasName ;
                            rr:objectMap [ rr:template "http://belhisfirm.be/resource/stock_name/{id}" ] ] .

:STOCK-NAME-TYPE
    a               rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
                    SELECT name, RAWTOHEX(STANDARD_HASH(stock || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) as id
                    FROM scoball.stock_name
    """ ] ;
    rr:subjectMap   [ rr:template "http://belhisfirm.be/resource/stock_name/{id}" ;
                      rr:class    bhf:DatedName ] .

:STOCK-NAME-PROPERTIES
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT RAWTOHEX(STANDARD_HASH(stock || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) as id,
                           CASE
                               WHEN startdate <= TO_DATE('1005-12-31','YYYY-MM-DD') THEN NULL
                               ELSE TO_CHAR(startdate, 'YYYY-MM-DD')
                           END AS startdate_fixed,
                           CASE
                               WHEN enddate >= TO_DATE('3900-01-01','YYYY-MM-DD') THEN NULL
                               ELSE TO_CHAR(enddate, 'YYYY-MM-DD')
                           END AS enddate_fixed,
                           name
                    FROM scoball.stock_name
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/stock_name/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate rdfs:label ;
                            rr:objectMap [ rr:column   "name" ;
                                           rr:datatype xsd:string ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:startDate ;
                            rr:objectMap [ rr:column   "startdate_fixed" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:endDate ;
                            rr:objectMap [ rr:column   "enddate_fixed" ;
                                           rr:datatype xsd:date ] ] .

:STOCK-SHARETYPE
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT s.id AS stock_id,
                           st.name AS sharetype_name
                    FROM scoball.stock s
                    JOIN scoball.sharetype st
                           ON s.sharetype = st.id
                    WHERE sharetype IN (1,2)
        """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/stock/{stock_id}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasSharetype ;
                            rr:objectMap [ rr:column   "sharetype_name" ;
                                           rr:datatype xsd:string ] ] .

:STOCK-NOTATION
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT id, stock FROM scoball.notation
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/stock/{stock}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasNotation ;
                            rr:objectMap [ rr:template "http://belhisfirm.be/resource/notation/{id}" ] ] .

:STOCK-STOCKTYPE
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT stock, RAWTOHEX(STANDARD_HASH(stock || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) as id
                    FROM scoball.stock_type
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/stock/{stock}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasStockType ;
                            rr:objectMap [ rr:template "http://belhisfirm.be/resource/stocktype/{id}" ] ] .

###################
# NOTATION
##################
:NOTATION-TYPE
    a               rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
                    SELECT id FROM scoball.notation
    """ ] ;
    rr:subjectMap   [ rr:template "http://belhisfirm.be/resource/notation/{id}" ;
                      rr:class    bhf:Notation ] .

:NOTATION-PROPERTIES
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT id, sector,
                           CASE
                               WHEN startdate <= TO_DATE('1005-12-31','YYYY-MM-DD') THEN NULL
                               ELSE TO_CHAR(startdate, 'YYYY-MM-DD')
                           END AS startdate_fixed,
                           CASE
                               WHEN enddate >= TO_DATE('3900-01-01','YYYY-MM-DD') THEN NULL
                               ELSE TO_CHAR(enddate, 'YYYY-MM-DD')
                           END AS enddate_fixed
                    FROM scoball.notation
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/notation/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasSector ;
                            rr:objectMap [ rr:template "http://belhisfirm.be/resource/sector/{sector}" ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:startDate ;
                            rr:objectMap [ rr:column   "startdate_fixed" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:endDate ;
                            rr:objectMap [ rr:column   "enddate_fixed" ;
                                           rr:datatype xsd:date ] ] .

# Reads from the SCOBALL.NOTATION_PRICE_YEARLY lens (see lenses.json), which computes the
# last recorded day per year per notation once. The lens declares a unique key on `id`,
# letting Ontop self-join-eliminate this mapping against :NOTATION-PRICE-TYPE.
:NOTATION-NOTATION-PRICE
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:tableName "scoball.notation_price_yearly" ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/notation/{notation}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasNotationPrice ;
                            rr:objectMap [ rr:template "http://belhisfirm.be/resource/notation_price/{id}" ] ] .


####################
## NOTATION-PRICE
###################

# Reads from the SCOBALL.NOTATION_PRICE_YEARLY lens (see lenses.json) instead of
# re-running the window query, so the windowed scan is evaluated once for both mappings.
:NOTATION-PRICE-TYPE
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:tableName "scoball.notation_price_yearly" ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/notation_price/{id}" ;
                            rr:class    bhf:NotationPrice ] ;
    rr:predicateObjectMap [ rr:predicate bhf:priceDay ;
                            rr:objectMap [ rr:column   "price_day" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:priceYearEnd ;
                            rr:objectMap [ rr:column   "price_year" ;
                                           rr:datatype xsd:integer ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:openValue ;
                            rr:objectMap [ rr:column   "open_value" ;
                                           rr:datatype xsd:integer ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:closeValue ;
                            rr:objectMap [ rr:column   "close_value" ;
                                           rr:datatype xsd:integer ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:previousValue ;
                            rr:objectMap [ rr:column   "previous_value" ;
                                           rr:datatype xsd:integer ] ] .


###################
# SECTOR
##################
:SECTOR-TYPE
    a               rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
                    SELECT id FROM scoball.sector
    """ ] ;
    rr:subjectMap   [ rr:template "http://belhisfirm.be/resource/sector/{id}" ;
                      rr:class    bhf:Sector ] .

:SECTOR-PROPERTIES
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT id,
                           CASE
                               WHEN startdate <= TO_DATE('1005-12-31','YYYY-MM-DD') THEN NULL
                               ELSE TO_CHAR(startdate, 'YYYY-MM-DD')
                           END AS startdate_fixed,
                           CASE
                               WHEN enddate >= TO_DATE('3900-01-01','YYYY-MM-DD') THEN NULL
                               ELSE TO_CHAR(enddate, 'YYYY-MM-DD')
                           END AS enddate_fixed
                    FROM scoball.sector
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/sector/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:startDate ;
                            rr:objectMap [ rr:column   "startdate_fixed" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:endDate ;
                            rr:objectMap [ rr:column   "enddate_fixed" ;
                                           rr:datatype xsd:date ] ] .

:SECTOR-NAME
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT sector,
                           RAWTOHEX(STANDARD_HASH(sector || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) as id
                    FROM scoball.sector_name
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/sector/{sector}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasName ;
                            rr:objectMap [ rr:template "http://belhisfirm.be/resource/sector_name/{id}" ] ] .

:SECTOR-NAME-TYPE
    a               rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
                    SELECT RAWTOHEX(STANDARD_HASH(sector || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) as id
                    FROM scoball.sector_name
    """ ] ;
    rr:subjectMap   [ rr:template "http://belhisfirm.be/resource/sector_name/{id}" ;
                      rr:class    bhf:DatedName ] .

:SECTOR-NAME-PROPERTIES
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT RAWTOHEX(STANDARD_HASH(sector || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) as id,
                           CASE
                               WHEN startdate <= TO_DATE('1005-12-31','YYYY-MM-DD') THEN NULL
                               ELSE TO_CHAR(startdate, 'YYYY-MM-DD')
                           END AS startdate_fixed,
                           CASE
                               WHEN enddate >= TO_DATE('3900-01-01','YYYY-MM-DD') THEN NULL
                               ELSE TO_CHAR(enddate, 'YYYY-MM-DD')
                           END AS enddate_fixed,
                           name
                    FROM scoball.sector_name
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/sector_name/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate rdfs:label ;
                            rr:objectMap [ rr:column   "name" ;
                                           rr:datatype xsd:string ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:startDate ;
                            rr:objectMap [ rr:column   "startdate_fixed" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:endDate ;
                            rr:objectMap [ rr:column   "enddate_fixed" ;
                                           rr:datatype xsd:date ] ] .


###################
# STOCK-TYPE
##################
:STOCK-TYPE-TYPE
    a               rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
                    SELECT RAWTOHEX(STANDARD_HASH(stock || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) as id
                    FROM scoball.stock_type
    """ ] ;
    rr:subjectMap   [ rr:template "http://belhisfirm.be/resource/stocktype/{id}" ;
                      rr:class    bhf:StockType ] .

:STOCK-TYPE-PROPERTIES
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT RAWTOHEX(STANDARD_HASH(stock || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) as id,
                    CASE
                        WHEN startdate <= TO_DATE('1005-12-31','YYYY-MM-DD') THEN NULL
                       ELSE TO_CHAR(startdate, 'YYYY-MM-DD')
                    END AS startdate_fixed,
                    CASE
                        WHEN enddate >= TO_DATE('3900-01-01','YYYY-MM-DD') THEN NULL
                        ELSE TO_CHAR(enddate, 'YYYY-MM-DD')
                    END AS enddate_fixed
                    FROM scoball.stock_type
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/stocktype/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:startDate ;
                            rr:objectMap [ rr:column   "startdate_fixed" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:endDate ;
                            rr:objectMap [ rr:column   "enddate_fixed" ;
                                           rr:datatype xsd:date ] ] .

:STOCK-TYPE-NAME
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT sn.name as name,
                           RAWTOHEX(STANDARD_HASH(st.stock || TO_CHAR(st.startdate,'YYYY-MM-DD'), 'SHA1')) as id
                    FROM scoball.stock_type st
                    JOIN scoball.stocktype sn
                    ON st.type = sn.id
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/stocktype/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:typeName ;
                            rr:objectMap [ rr:column   "name" ;
                                           rr:datatype xsd:string ] ] .

:STOCK-TYPE-COMPREF
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT cm.compref as compref,
                           RAWTOHEX(STANDARD_HASH(st.stock || TO_CHAR(st.startdate,'YYYY-MM-DD'), 'SHA1')) as id
                    FROM scoball.stock_type st
                    JOIN scoball.stock_type_compref cm
                    ON st.compref = cm.id
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/stocktype/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:compref ;
                            rr:objectMap [ rr:column   "compref" ;
                                           rr:datatype xsd:string ] ] .


###################
# STOCK-CORPORATION
##################
:STOCK-CORPORATION-TYPE
    a               rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
                    SELECT RAWTOHEX(STANDARD_HASH(stock || corporation || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) AS id
                    FROM scoball.stock_corporation
    """ ] ;
    rr:subjectMap   [ rr:template "http://belhisfirm.be/resource/stockcorporation/{id}" ;
                      rr:class    bhf:StockCorporation ] .

:STOCK-CORPORATION-PROPERTIES
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT RAWTOHEX(STANDARD_HASH(stock || corporation || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) AS id,
                           CASE
                               WHEN startdate <= TO_DATE('1005-12-31','YYYY-MM-DD') THEN NULL
                              ELSE TO_CHAR(startdate, 'YYYY-MM-DD')
                           END AS startdate_fixed,
                           CASE
                               WHEN enddate >= TO_DATE('3900-01-01','YYYY-MM-DD') THEN NULL
                               ELSE TO_CHAR(enddate, 'YYYY-MM-DD')
                           END AS enddate_fixed,
                           stock
                    FROM scoball.stock_corporation
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/stockcorporation/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasStock ;
                            rr:objectMap [ rr:template "http://belhisfirm.be/resource/stock/{stock}" ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:startDate ;
                            rr:objectMap [ rr:column   "startdate_fixed" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:endDate ;
                            rr:objectMap [ rr:column   "enddate_fixed" ;
                                           rr:datatype xsd:date ] ] .


###################
# STOCK-QUANTITY
##################
:STOCK-QUANTITY-TYPE
    a               rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
                    SELECT RAWTOHEX(STANDARD_HASH(stock || type || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) as id
                    FROM scoball.stock_quantity
    """ ] ;
    rr:subjectMap   [ rr:template "http://belhisfirm.be/resource/stockquantity/{id}" ;
                      rr:class    bhf:StockQuantity ] .

:STOCK-QUANTITY-TYPENAME
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT RAWTOHEX(STANDARD_HASH(sq.stock || sq.type || TO_CHAR(sq.startdate,'YYYY-MM-DD'), 'SHA1')) as id,
                           qt.name as name
                    FROM scoball.stock_quantity sq
                    JOIN scoball.quantitytype qt
                    ON sq.type = qt.id
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/stockquantity/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:quantityType ;
                            rr:objectMap [ rr:column   "name" ;
                                           rr:datatype xsd:string ] ] .

:STOCK-QUANTITY-PROPERTIES
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT RAWTOHEX(STANDARD_HASH(stock || type || TO_CHAR(startdate,'YYYY-MM-DD'), 'SHA1')) as id,
                           volume,
                           value,
                           currency,
                           CASE
                               WHEN startdate <= TO_DATE('1005-12-31','YYYY-MM-DD') THEN NULL
                               ELSE TO_CHAR(startdate, 'YYYY-MM-DD')
                           END AS startdate_fixed,
                           CASE
                               WHEN enddate >= TO_DATE('3900-01-01','YYYY-MM-DD') THEN NULL
                               ELSE TO_CHAR(enddate, 'YYYY-MM-DD')
                           END AS enddate_fixed
                    FROM scoball.stock_quantity
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/stockquantity/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate bhf:quantityVolume ;
                            rr:objectMap [ rr:column   "volume" ;
                                           rr:datatype xsd:integer ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:quantityValue ;
                            rr:objectMap [ rr:column   "value" ;
                                           rr:datatype xsd:integer ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:hasCurrency ;
                            rr:objectMap [ rr:template "http://belhisfirm.be/resopricurce/currency/{currency}" ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:startDate ;
                            rr:objectMap [ rr:column   "startdate_fixed" ;
                                           rr:datatype xsd:date ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:endDate ;
                            rr:objectMap [ rr:column   "enddate_fixed" ;
                                           rr:datatype xsd:date ] ] .


###################
# CURRENCY
##################
:CURRENCY-TYPE
    a               rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
                    SELECT id FROM scoball.currency
    """ ] ;
    rr:subjectMap   [ rr:template "http://belhisfirm.be/resource/currency/{id}" ;
                      rr:class    bhf:Currency ] .

:CURRENCY-PROPERTIES
    a                     rr:TriplesMap ;
    rr:logicalTable       [ rr:sqlQuery """
                    SELECT id, name, country, comments FROM scoball.currency
    """ ] ;
    rr:subjectMap         [ rr:template "http://belhisfirm.be/resource/currency/{id}" ] ;
    rr:predicateObjectMap [ rr:predicate foaf:name ;
                            rr:objectMap [ rr:column   "name" ;
                                           rr:datatype xsd:string ] ] ;
    rr:predicateObjectMap [ rr:predicate vcard:country-name ;
                            rr:objectMap [ rr:column   "country" ;
                                           rr:datatype xsd:string ] ] ;
    rr:predicateObjectMap [ rr:predicate bhf:comments ;
                            rr:objectMap [ rr:column   "comments" ;
                                           rr:datatype xsd:string ] ] .
